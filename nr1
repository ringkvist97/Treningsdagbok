<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Treningsdagbok</title>
  <style>
    :root {
      --bg: #0b0f13;
      --bg-elev: #141a22;
      --bg-elev-2: #1b2430;
      --border: #243042;
      --text: #e6edf3;
      --text-dim: #8b96a5;
      --accent: #00ff88;
      --accent-dim: #00cc6a;
      --danger: #ff4d6d;
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      min-height: 100vh;
    }

    body {
      background:
        radial-gradient(1000px 500px at 10% -10%, rgba(0, 255, 136, 0.08), transparent 60%),
        radial-gradient(800px 400px at 110% 10%, rgba(0, 204, 255, 0.06), transparent 60%),
        var(--bg);
    }

    header {
      padding: 32px 24px 16px;
      text-align: center;
      border-bottom: 1px solid var(--border);
    }

    header h1 {
      margin: 0;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    header h1 .accent {
      color: var(--accent);
      text-shadow: 0 0 12px rgba(0, 255, 136, 0.5);
    }

    header p {
      color: var(--text-dim);
      margin: 8px 0 0;
      font-size: 0.95rem;
    }

    main {
      max-width: 860px;
      margin: 0 auto;
      padding: 24px 16px 80px;
      display: grid;
      gap: 24px;
    }

    .card {
      background: var(--bg-elev);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 20px;
      box-shadow: var(--shadow);
    }

    .card h2 {
      margin: 0 0 16px;
      font-size: 1.1rem;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .card h2::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 10px var(--accent);
    }

    form {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    form .full { grid-column: 1 / -1; }

    label {
      display: block;
      font-size: 0.8rem;
      color: var(--text-dim);
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    input, textarea, select {
      width: 100%;
      background: var(--bg-elev-2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 10px 12px;
      border-radius: 8px;
      font-size: 0.95rem;
      font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    input:focus, textarea:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.15);
    }

    textarea { resize: vertical; min-height: 60px; }

    button {
      font-family: inherit;
      cursor: pointer;
      border: none;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 0.95rem;
      font-weight: 600;
      transition: transform 0.1s, box-shadow 0.15s, background 0.15s;
    }

    .btn-primary {
      background: var(--accent);
      color: #001912;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      box-shadow: 0 6px 20px rgba(0, 255, 136, 0.25);
    }

    .btn-primary:hover {
      background: var(--accent-dim);
      transform: translateY(-1px);
    }

    .btn-ghost {
      background: transparent;
      color: var(--text-dim);
      border: 1px solid var(--border);
      padding: 6px 10px;
      font-size: 0.8rem;
    }

    .btn-ghost:hover {
      color: var(--text);
      border-color: var(--text-dim);
    }

    .btn-danger {
      background: transparent;
      color: var(--danger);
      border: 1px solid rgba(255, 77, 109, 0.3);
      padding: 6px 10px;
      font-size: 0.8rem;
    }

    .btn-danger:hover {
      background: rgba(255, 77, 109, 0.1);
    }

    .history-controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .search {
      flex: 1;
      min-width: 180px;
    }

    .stats {
      color: var(--text-dim);
      font-size: 0.85rem;
    }

    .stats strong {
      color: var(--accent);
      font-size: 1rem;
    }

    .day-group {
      margin-bottom: 20px;
    }

    .day-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
      margin-bottom: 10px;
    }

    .day-header h3 {
      margin: 0;
      font-size: 1rem;
      color: var(--accent);
      text-transform: capitalize;
    }

    .day-header span {
      color: var(--text-dim);
      font-size: 0.8rem;
    }

    .entry {
      background: var(--bg-elev-2);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px 14px;
      margin-bottom: 8px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: center;
    }

    .entry-main {
      display: grid;
      gap: 4px;
    }

    .entry-title {
      font-weight: 600;
      font-size: 1rem;
    }

    .entry-meta {
      color: var(--text-dim);
      font-size: 0.85rem;
    }

    .entry-meta .chip {
      display: inline-block;
      background: rgba(0, 255, 136, 0.08);
      color: var(--accent);
      padding: 2px 8px;
      border-radius: 999px;
      margin-right: 4px;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .entry-notes {
      color: var(--text-dim);
      font-size: 0.85rem;
      font-style: italic;
      margin-top: 2px;
    }

    .empty {
      text-align: center;
      color: var(--text-dim);
      padding: 30px 10px;
      font-size: 0.95rem;
    }

    @media (max-width: 520px) {
      form { grid-template-columns: 1fr 1fr; }
      form .full { grid-column: 1 / -1; }
    }

    footer {
      text-align: center;
      color: var(--text-dim);
      font-size: 0.8rem;
      padding: 20px;
    }
  </style>
</head>
<body>
  <header>
    <h1>Trenings<span class="accent">dagbok</span></h1>
    <p>Logg hver økt. Se fremgangen.</p>
  </header>

  <main>
    <section class="card">
      <h2>Ny økt</h2>
      <form id="workout-form">
        <div class="full">
          <label for="exercise">Øvelse</label>
          <input type="text" id="exercise" placeholder="f.eks. Markløft" required />
        </div>
        <div>
          <label for="sets">Sett</label>
          <input type="number" id="sets" min="1" step="1" placeholder="3" required />
        </div>
        <div>
          <label for="reps">Reps</label>
          <input type="number" id="reps" min="1" step="1" placeholder="8" required />
        </div>
        <div>
          <label for="weight">Vekt (kg)</label>
          <input type="number" id="weight" min="0" step="0.5" placeholder="80" />
        </div>
        <div>
          <label for="datetime">Dato og tidspunkt</label>
          <input type="datetime-local" id="datetime" required />
        </div>
        <div class="full">
          <label for="notes">Notat (valgfritt)</label>
          <textarea id="notes" placeholder="Hvordan føltes økten?"></textarea>
        </div>
        <div class="full">
          <button type="submit" class="btn-primary">Lagre økt</button>
        </div>
      </form>
    </section>

    <section class="card">
      <h2>Historikk</h2>
      <div class="history-controls">
        <input type="search" id="search" class="search" placeholder="Søk i øvelser eller notater..." />
        <div class="stats" id="stats">0 økter lagret</div>
        <button type="button" id="export-btn" class="btn-ghost">Eksporter</button>
      </div>
      <div id="history"></div>
    </section>
  </main>

  <footer>Data lagres lokalt i nettleseren din.</footer>

  <script>
    const STORAGE_KEY = 'treningsdagbok.entries.v1';
    const form = document.getElementById('workout-form');
    const historyEl = document.getElementById('history');
    const statsEl = document.getElementById('stats');
    const searchEl = document.getElementById('search');
    const exportBtn = document.getElementById('export-btn');
    const dtInput = document.getElementById('datetime');

    // Forhåndsfyll datetime med «nå»
    function setNow() {
      const d = new Date();
      d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
      dtInput.value = d.toISOString().slice(0, 16);
    }
    setNow();

    function load() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? JSON.parse(raw) : [];
      } catch (e) {
        console.error('Kunne ikke lese lagrede data', e);
        return [];
      }
    }

    function save(entries) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
    }

    function formatDateKey(iso) {
      // Grupper etter dato i lokal tid
      const d = new Date(iso);
      return d.toLocaleDateString('no-NO', {
        weekday: 'long',
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });
    }

    function formatTime(iso) {
      const d = new Date(iso);
      return d.toLocaleTimeString('no-NO', { hour: '2-digit', minute: '2-digit' });
    }

    function render() {
      const all = load();
      const query = searchEl.value.trim().toLowerCase();

      const filtered = query
        ? all.filter(e =>
            (e.exercise || '').toLowerCase().includes(query) ||
            (e.notes || '').toLowerCase().includes(query)
          )
        : all;

      statsEl.innerHTML = `<strong>${all.length}</strong> økt${all.length === 1 ? '' : 'er'} lagret`;

      if (filtered.length === 0) {
        historyEl.innerHTML = `<div class="empty">${
          all.length === 0
            ? 'Ingen økter ennå. Legg til din første over.'
            : 'Ingen treff på søket ditt.'
        }</div>`;
        return;
      }

      // Sorter nyeste først
      const sorted = [...filtered].sort((a, b) => new Date(b.datetime) - new Date(a.datetime));

      // Grupper etter dato
      const groups = new Map();
      for (const e of sorted) {
        const key = formatDateKey(e.datetime);
        if (!groups.has(key)) groups.set(key, []);
        groups.get(key).push(e);
      }

      let html = '';
      for (const [day, items] of groups) {
        html += `<div class="day-group">
          <div class="day-header">
            <h3>${escapeHtml(day)}</h3>
            <span>${items.length} øvelse${items.length === 1 ? '' : 'r'}</span>
          </div>`;
        for (const e of items) {
          const weightText = e.weight ? `${e.weight} kg` : 'kroppsvekt';
          html += `
            <div class="entry">
              <div class="entry-main">
                <div class="entry-title">${escapeHtml(e.exercise)}</div>
                <div class="entry-meta">
                  <span class="chip">${e.sets} × ${e.reps}</span>
                  <span class="chip">${escapeHtml(weightText)}</span>
                  <span>${formatTime(e.datetime)}</span>
                </div>
                ${e.notes ? `<div class="entry-notes">${escapeHtml(e.notes)}</div>` : ''}
              </div>
              <button type="button" class="btn-danger" data-id="${e.id}">Slett</button>
            </div>`;
        }
        html += `</div>`;
      }
      historyEl.innerHTML = html;

      // Koble opp slett-knapper
      historyEl.querySelectorAll('button[data-id]').forEach(btn => {
        btn.addEventListener('click', () => deleteEntry(btn.dataset.id));
      });
    }

    function escapeHtml(str) {
      return String(str).replace(/[&<>"']/g, c => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[c]));
    }

    function deleteEntry(id) {
      if (!confirm('Slette denne øvelsen?')) return;
      const entries = load().filter(e => e.id !== id);
      save(entries);
      render();
    }

    form.addEventListener('submit', (ev) => {
      ev.preventDefault();
      const entry = {
        id: Date.now().toString(36) + Math.random().toString(36).slice(2, 8),
        exercise: document.getElementById('exercise').value.trim(),
        sets: parseInt(document.getElementById('sets').value, 10),
        reps: parseInt(document.getElementById('reps').value, 10),
        weight: document.getElementById('weight').value
          ? parseFloat(document.getElementById('weight').value)
          : null,
        datetime: new Date(dtInput.value).toISOString(),
        notes: document.getElementById('notes').value.trim()
      };
      const entries = load();
      entries.push(entry);
      save(entries);

      // Nullstill skjemaet, men behold dato/tid så det er enkelt å legge til neste øvelse i samme økt
      const keepDate = dtInput.value;
      form.reset();
      dtInput.value = keepDate;

      render();
    });

    searchEl.addEventListener('input', render);

    exportBtn.addEventListener('click', () => {
      const data = load();
      if (data.length === 0) {
        alert('Ingen økter å eksportere.');
        return;
      }
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `treningsdagbok-${new Date().toISOString().slice(0, 10)}.json`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    });

    render();
  </script>
</body>
</html>
